@rendermode InteractiveServer

<h3>Barcode Navigation Sandbox</h3>

<button class="btn btn-primary" @onclick="HandleClick" @ref="scanButton">@buttonText</button>

<p>Listening: @IsDetecting</p>
<p>Collected Input: @DetectionString</p>

@code {
    private bool IsDetecting = false;
    private string DetectionString = "";
    private ElementReference scanButton;

    [Inject] IJSRuntime JS { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;

    // The JS key listener is started/stopped when the Scan button is toggled.

    [JSInvokable]
    public void ReceiveKey(string key)
    {
        // Start listening on =
        if (!IsDetecting && key == "=")
        {
            IsDetecting = true;
            DetectionString = "";
            StateHasChanged();
            return;
        }

        if (IsDetecting)
        {
            if (key == "Enter")
            {
                Console.WriteLine(DetectionString);

                // Navigate based on collected input
                switch (DetectionString)
                {
                    case "*JHWEB40.LIT.40630*":
                        Nav.NavigateTo("/1");
                        break;
                    case "*JHWEB40.LIT.40631*":
                        Nav.NavigateTo("/2");
                        break;

                        //=*JHWEB40.LIT.40630*
                        //=*JHWEB40.LIT.40631*
                }
                // Reset
                IsDetecting = false;
                DetectionString = "";
                StateHasChanged();

                // Remove focus from the button so ENTER doesn't trigger it again
                _ = JS.InvokeVoidAsync("blurElement", scanButton);
            }
            else
            {
                // Only append real characters
                if (key.Length == 1)
                {
                    DetectionString += key;
                    StateHasChanged();
                }
            }
        }
    }

    // scan button logic
    private string buttonText = "Scan";
    private bool isScanning = false;
    private DotNetObjectReference<Sandbox>? dotNetRef;

    private async Task HandleClick()
    {
        ToggleStatus();

        if (isScanning)
        {
            // start JS key listener and pass a DotNet reference
            dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("startKeyListener", dotNetRef);
        }
        else
        {
            // stop JS key listener and dispose the reference
            await JS.InvokeVoidAsync("stopKeyListener");
            dotNetRef?.Dispose();
            dotNetRef = null;
        }
    }

    private void ToggleStatus()
    {
        isScanning = !isScanning;

        if (isScanning)
        {
            buttonText = "Scanning";
        }
        else
        {
            buttonText = "Scan";
        }
    }
}